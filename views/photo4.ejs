<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="./ak2.png">
    <title>OG-TerraForge</title>
    <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 0;
    }

   header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 50px;
      border-bottom: 1px solid #ddd;
      background-color:#03131a;
    }
    /* .logo {
      font-size: 32px;
      font-weight: bold;
    } */
    #logo{
        height: 45px;
        width: 70px;
    }
     .txt{
        color: rgba(255, 255, 255, 0.5);;
        font-size: 19px;
        font-weight: bold;
    }
    nav{
       margin-right: 180px;
    }
    nav a {
      margin: 0 25px;
      text-decoration: none;
      color: aliceblue;
      font-weight: bold;
      transition: all 0.3s ease;
      font-size: 19px;
    }
    .nav-txt{
        position: relative;
        left: 50px;
    }
    .nav-txt:hover{
        transform: scale(1.1,1.1);
        color: gray;
    }

    #btn-log a{
      color:#03131a; 
        font-weight: bold;
    }
    #btn-log{
    padding: 4px;
    position:relative;
    left: 180px;
    font-size: 29px;
    border: 1px solid black;
    border-radius: 20px;
    background-color:aliceblue;
    transition: all 0.5s ease;
    }
    #btn-log:hover{
      transform: scale(1.1,1.1);
    }
    .container {
      display: flex;
      /* flex-wrap: wrap; */
      padding: 10px;
      /* align-items: center; */
      justify-content: space-around;
      /* border: 1px solid black; */
     
    }
    .text-content {
      max-width: 500px;
      padding-left: 50px;
      margin-top: 45px;
      
    }
    .title {
      font-size: 40px;
      font-weight: bold;
    }

    .subtitle {
      font-size: 25px;
      color: #cc7722;
      margin-top: -10px;
      font-weight: bold;
    }

    .description {
      font-size: 15px;
      text-transform: uppercase;
      margin-top: 20px;
      font-weight: bold;
    }

    .price {
      font-size: 32px;
      margin-top: 30px;
      font-weight: bold;
    }

    .btn {
      background-color: #ddd;
      border: 1px solid black;
      padding: 15px 30px;
      font-size: 16px;
      font-weight: bold;
      border-radius: 12px;
      cursor: pointer;
      margin-top: 20px;
      box-shadow: 4px 4px 8px rgba(0,0,0,0.5);
    }
    .btn a{
      color: black;
      text-decoration: none;
    }
    .shoe-image{
      display: flex;
      justify-content: center;
      cursor: pointer;
    }
    .small-image{
      display: flex;
      flex-direction: column;
      justify-content:space-evenly;
      margin-right: 40px;
    }
    .big-image img{
      margin-left: 30px;
      position: relative;
      bottom: 25px;
      /* border: 1px solid black; */
    }
    .small-image img{
      height: 50px;
      width: 57px;
      border: 1px solid black;
    }
    .shoe-image img {
      max-width: 425px;
      max-height: 425px;
      /* transform: rotate(1deg); */
      padding-top: 15px;
    }

    #select-size{
      width: 60px;
      height: 35px;
      text-align: center;
      font-size: 18px;
      border-radius: 10px;
      border: 2px solid black;
      font-weight: bold;
      margin-top: 7px;
    }

     .foot-panal4{
    background-color:#03131a;
    color: white;
    height: 85px;
    font-size: 0.8rem;
    text-align: center;
    /* background-color: black; */
    border-top: 2px solid aliceblue;
}
.pages{
    padding-top:18px;
}
.copyright{
    padding-top: 5px;
}
.copyright span{
    color:rgba(255, 255, 255, 0.6);
    font-size: 15px;
}
  </style>
</head>
<body>
   <header>
    <div class="logo">
      <img src="ak2.png" id="logo" alt="image">
       <div class="txt">
                FOOTWARE
        </div>
    </div>
    <nav>
      <a href="http://localhost:3000/akfootware" class="nav-txt">HOME</a>
      <a href="http://localhost:3000/akproduct" class="nav-txt">PRODUCT</a>
      <a href="http://localhost:3000/akabout" class="nav-txt">ABOUT</a>
      <a href="http://localhost:3000/contect" class="nav-txt">CONTECT</a>
      <a href="http://localhost:3000/review" class="nav-txt">REVIEW</a>
      <button id="btn-log">
        <a href="http://localhost:3000/ab.html" class="log-txt">LOGIN</a>
        </button>
    </nav>
  </header>

  <div class="container">
    
       <div class="shoe-image">
       
      <div class="small-image">
         <img src="14-1.jpeg" alt="image" class="featured-image-1">
        <img src="14.jpg" alt="image" class="featured-image-1">
        <img src="14-4.jpg" alt="image" class="featured-image-1">
        <img src="14-6.png" alt="image" class="featured-image-1">
        <img src="14-5.jpg" alt="image" class="featured-image-1">
      </div>

       <div class="big-image">
      <img src="14-1.jpeg" class="big-image-1" alt="G-Classic Walking Shoe">
      </div>

    </div>

    <div class="text-content">
      <div class="title">OG-TerraForge</div>
      <div class="subtitle">Snackers Shoes</div>
      <div class="description">
        Celebrating the Snackers in original form as first introduced during Undercover’s Autumn Winter 2021 presentation. Genuine block leather takes over the upper while a smooth leather and texture look old and Snackers
      </div>
      <div class="price">price:₹1900</div>
      <div class="size">
        <select name="" id="select-size">
          <option value="1" selected>Size</option>
          <option value="40" id="fourty">40</option>
          <option value="41" id="fourtyone">41</option>
          <option value="42" id="fourtytwo">42</option>
          <option value="43" id="fourtythree">43</option>
          <option value="44" id="fourtyfour">44</option>
          <option value="45" id="fourtyfive">45</option>
        </select>
      </div>
      <button class="btn"><a href="#">buy now</a></button>
    </div>

  </div>

    <div class="foot-panal4">
            <div class="pages">
                <a>Condition of Use</a>
                <a>Privacy Notice</a>
                <a>Your Ads Privace Choice</a>
            </div>
            <div class="copyright">
                2025,kanodar, Inc.or its affiliates<br>
                Develop by <span>Suleman</span> & <span>Chaudhary</span>.
            </div>
        </div>

  <!-- javascript -->

  <script>
    const sizePriceMap={
         1:1900,
        40:1900,
        41:1960,
        42:2000,
        43:2100,
        44:2150,
        45:2200
    };
    document.querySelector("#select-size").addEventListener("change",function(){
        const selectedSize = this.value;
        document.querySelector(".price").innerText = `Price:₹${sizePriceMap[selectedSize]}`
    });

    document.querySelectorAll(".featured-image-1").forEach(image_1 => {
        image_1.addEventListener("click",() =>{
            let change = image_1.getAttribute('src');
            document.querySelector(".big-image-1").src = change;
    });
    });

  </script>
</body>
</html>