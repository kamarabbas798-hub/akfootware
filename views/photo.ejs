<!-- javascript -->
  <script>

      const sizePriceMap = {
        1:650,
        40: 650,
        41: 700,
        42: 750,
        43:790,
        44:820,
        45:850 
};

document.querySelector("#select-size").addEventListener("change", function () {
    const selectedSize = this.value;
    document.querySelector(".price").innerText = `Price:₹${sizePriceMap[selectedSize]}`;
});

      document.querySelectorAll('.featured-image-1').forEach(image_1 =>{
      image_1.addEventListener('click',() =>{
        let change =image_1.getAttribute('src');
        document.querySelector('.big-image-1').src = change;
      });
    });
  </script>

