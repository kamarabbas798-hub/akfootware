<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AK FOOTWARE</title>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- NAVBAR -->
<header class="navbar-section">
  <div class="container-fluid nav-container">

    <div class="logo-section">
      <img src="ak2.png" alt="logo">
      <h2>FOOTWARE</h2>
    </div>

    <nav id="navbar">
      <a href="#">HOME</a>
      <a href="#products">PRODUCTS</a>
      <a href="#about">ABOUT</a>
      <a href="#contact">CONTACT</a>
      <a href="#review">REVIEW</a>
    </nav>

    <div class="nav-icons">
      <i class="fa-solid fa-magnifying-glass"></i>
      <i class="fa-solid fa-cart-shopping"></i>
      <button>LOGIN</button>
    </div>

    <div class="menu-toggle" id="menu-toggle">
      <i class="fa-solid fa-bars"></i>
    </div>

  </div>
</header>


<!-- HERO SECTION -->
<section class="hero-section">

  <div class="overlay"></div>

  <div class="hero-content">
    <h1>NEW COLLECTION</h1>
    <h2>KICKS STYLE PREMIUM SHOES</h2>

    <p>
      Discover premium sneakers crafted for comfort,
      performance and streetwear fashion.
    </p>

    <div class="hero-buttons">
      <button class="shop-btn">SHOP NOW</button>
      <button class="explore-btn">EXPLORE</button>
    </div>
  </div>

</section>


<!-- FEATURES -->
<section class="features-section">

  <div class="feature-box">
    <i class="fa-solid fa-truck"></i>
    <h3>Free Delivery</h3>
  </div>

  <div class="feature-box">
    <i class="fa-solid fa-shield"></i>
    <h3>Secure Payment</h3>
  </div>

  <div class="feature-box">
    <i class="fa-solid fa-rotate-left"></i>
    <h3>Easy Returns</h3>
  </div>

  <div class="feature-box">
    <i class="fa-solid fa-headset"></i>
    <h3>24/7 Support</h3>
  </div>

</section>


<!-- PRODUCTS -->
<section class="products-section" id="products">

  <div class="section-title">
    <h1>PREMIUM PRODUCTS</h1>
  </div>

  <div class="product-grid">

    <div class="product-card">
      <div class="product-image">
        <img src="10-3.jpg" alt="shoe">
      </div>

      <div class="product-content">
        <h3>Leo Fitness Sports</h3>
        <p>Premium Running Sneakers</p>

        <div class="price-row">
          <span>₹1500</span>
          <button>Buy Now</button>
        </div>
      </div>
    </div>


    <div class="product-card">
      <div class="product-image">
        <img src="2-3.webp" alt="shoe">
      </div>

      <div class="product-content">
        <h3>Dark Knight 2.0</h3>
        <p>Streetwear Premium Shoes</p>

        <div class="price-row">
          <span>₹4000</span>
          <button>Buy Now</button>
        </div>
      </div>
    </div>


    <div class="product-card">
      <div class="product-image">
        <img src="14-1.jpg" alt="shoe">
      </div>

      <div class="product-content">
        <h3>OG TerraForge</h3>
        <p>Comfort Lifestyle Shoes</p>

        <div class="price-row">
          <span>₹1900</span>
          <button>Buy Now</button>
        </div>
      </div>
    </div>


    <div class="product-card">
      <div class="product-image">
        <img src="br.jpg" alt="shoe">
      </div>

      <div class="product-content">
        <h3>Streetwear Sneakers</h3>
        <p>Fashion Collection</p>

        <div class="price-row">
          <span>₹2500</span>
          <button>Buy Now</button>
        </div>
      </div>
    </div>


    <div class="product-card">
      <div class="product-image">
        <img src="5-4.webp" alt="shoe">
      </div>

      <div class="product-content">
        <h3>Zixer Sneakers</h3>
        <p>Modern Premium Sneakers</p>

        <div class="price-row">
          <span>₹1800</span>
          <button>Buy Now</button>
        </div>
      </div>
    </div>


    <div class="product-card">
      <div class="product-image">
        <img src="4.jpg" alt="shoe">
      </div>

      <div class="product-content">
        <h3>Scaler Sneakers</h3>
        <p>Minimal Style Collection</p>

        <div class="price-row">
          <span>₹1200</span>
          <button>Buy Now</button>
        </div>
      </div>
    </div>

  </div>

</section>


<!-- BANNER -->
<section class="banner-section">
  <div class="banner-content">
    <h1>LIMITED EDITION</h1>
    <p>Feel the energy of premium street fashion.</p>
    <button>SHOP COLLECTION</button>
  </div>
</section>


<!-- FOOTER -->
<footer>

  <div class="footer-container">

    <div class="footer-box">
      <h2>AK FOOTWARE</h2>
      <p>
        Premium sneaker destination for modern fashion lovers.
      </p>
    </div>


    <div class="footer-box">
      <h3>Quick Links</h3>
      <a href="#">Home</a>
      <a href="#">Products</a>
      <a href="#">About</a>
      <a href="#">Contact</a>
    </div>


    <div class="footer-box">
      <h3>Support</h3>
      <a href="#">FAQ</a>
      <a href="#">Shipping</a>
      <a href="#">Returns</a>
      <a href="#">Payments</a>
    </div>


    <div class="footer-box">
      <h3>Follow Us</h3>

      <div class="social-icons">
        <i class="fab fa-facebook-f"></i>
        <i class="fab fa-instagram"></i>
        <i class="fab fa-twitter"></i>
        <i class="fab fa-linkedin-in"></i>
      </div>
    </div>

  </div>

  <div class="copyright">
    © 2026 AK FOOTWARE | Designed By Suleman & Chaudhary
  </div>

</footer>


<script>

const toggle = document.getElementById('menu-toggle');
const navbar = document.getElementById('navbar');


toggle.addEventListener('click', ()=>{
  navbar.classList.toggle('active');
});

</script>

</body>
</html>

