  <title>Contact Us</title>
  
</head>
<body>
    <header>
    <div class="logo">
      <img src="ak2.png" id="logo" alt="image">
      <div class="txt">
        FOOTWARE
      </div>
    </div>
    <nav>
      <a href="http://localhost:3000/akfootware" class="nav-txt">HOME</a>
      <a href="http://localhost:3000/akproduct" class="nav-txt">PRODUCT</a>
